{
  "name": "ai-productivity-hub",
  "private": true,
  "version": "3.2.2",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "ELECTRON_RUN_AS_NODE= VITE_ELECTRON=true vite",
    "build": "tsc && vite build",
    "build:electron": "tsc && VITE_ELECTRON=true vite build && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.allen.logs2weekly",
    "productName": "Logs2Weekly",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Allen-cy",
        "repo": "Logs2Weekly",
        "releaseType": "release"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "artifactName": "${productName}-v${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "electron-updater": "^6.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^9.0.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-pwa": "^0.21.1"
  }
}